DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/call_analyzer

# Gemini mode: "proxy" (via proxy server) or "direct" (Google AI with API key)
GEMINI_MODE=proxy

# Proxy mode settings
# Use localhost for local dev, 172.17.0.1 for Docker on Linux
GEMINI_PROXY_URL=http://172.17.0.1:8000
GEMINI_PROJECT_ID=your-project-id
GEMINI_LOCATION=us-central1

# Direct mode settings
# GEMINI_API_KEY=your-google-ai-api-key

GEMINI_MODEL=gemini-2.5-flash
WATCH_DIR=./watch
UPLOAD_DIR=./uploads

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bivaetmail@gmail.com
SMTP_PASSWORD=<app-password>
ALERT_EMAIL_TO=bivaetmail@gmail.com
